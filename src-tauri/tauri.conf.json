{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LumenLan",
  "version": "0.1.0",
  "identifier": "com.lumenlan.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LumenLan",
        "width": 980,
        "height": 720,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
